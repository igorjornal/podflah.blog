# ── Banco de dados (Neon Postgres) ──────────────────────────────────
# Crie uma conta gratuita em https://neon.tech e copie a connection string
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/podflah?sslmode=require"

# ── Autenticação Admin ────────────────────────────────────────────────
# Gere o secret: openssl rand -base64 32
NEXTAUTH_SECRET="coloque-uma-string-aleatoria-longa-aqui"
NEXTAUTH_URL="https://podflah.blog"

# Nome de usuário do admin
ADMIN_USERNAME="igor"

# Hash bcrypt da senha. Para gerar:
#   node -e "const b=require('bcryptjs'); b.hash('SUA_SENHA',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH="$2b$12$..."

# ── Armazenamento de Imagens (Cloudflare R2) ─────────────────────────
# Crie uma conta gratuita em https://cloudflare.com → R2
R2_ACCOUNT_ID="seu-account-id"
R2_ACCESS_KEY_ID="sua-access-key"
R2_SECRET_ACCESS_KEY="sua-secret-key"
R2_BUCKET_NAME="podflah-media"
# URL pública do bucket (configure domínio personalizado no R2 ou use o r2.dev)
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
